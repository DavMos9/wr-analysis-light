# ─────────────────────────────────────────────────────────────
#  wr-analysis-light — variabili d'ambiente
#  Copia questo file in .env e inserisci le tue API key.
#  Il file .env non viene mai versionato.
# ─────────────────────────────────────────────────────────────

# ── News ──────────────────────────────────────────────────────
NEWS_API_KEY=
GUARDIAN_API_KEY=
NYT_API_KEY=

# ── Web search generalista ────────────────────────────────────
BRAVE_API_KEY=

# ── Social / UGC ─────────────────────────────────────────────
YOUTUBE_API_KEY=

# Bluesky (obbligatorio — endpoint pubblico non più accessibile anonimamente)
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Mastodon (opzionale — aumenta i limiti)
MASTODON_ACCESS_TOKEN=
MASTODON_TOKEN_INSTANCE=mastodon.social

# Istanze configurabili (default se non specificato)
# MASTODON_INSTANCES=mastodon.social,mastodon.online,techhub.social
# LEMMY_INSTANCES=lemmy.world,lemmy.ml,sh.itjust.works

# Stack Exchange (opzionale — senza key: 300 req/giorno; con key: 10.000/giorno)
STACKEXCHANGE_API_KEY=

# ── NLP enrichment (opzionale) ────────────────────────────────
# Token HuggingFace — non obbligatorio, ma aumenta il rate limit
# per il download del modello di sentiment (~1.1 GB, scaricato
# automaticamente al primo utilizzo con dipendenze [nlp]).
HF_TOKEN=
